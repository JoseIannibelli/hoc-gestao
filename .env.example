# Copie este arquivo para .env e preencha os valores
# NUNCA versione o arquivo .env — ele está no .gitignore

# ── Aplicação ──────────────────────────────────────────────────────────────────
# Gere uma chave forte em: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=troque-por-uma-chave-secreta-forte

# ── Banco de dados ─────────────────────────────────────────────────────────────
# Desenvolvimento (SQLite local):
# DATABASE_URL=sqlite:///hoc.db
#
# Produção (Railway PostgreSQL — gerado automaticamente pelo Railway):
# DATABASE_URL=postgresql://usuario:senha@host:5432/banco

# ── E-mail (reset de senha) ────────────────────────────────────────────────────
MAIL_ENABLED=false
MAIL_SERVER=smtp.office365.com
MAIL_PORT=587
MAIL_USE_TLS=true
MAIL_USERNAME=seu-email@hoc.com.br
MAIL_PASSWORD=sua-senha-de-app
MAIL_DEFAULT_SENDER=HOC Gestão <noreply@hoc.com.br>
